# Examples not for public distribution
examples/erp/

# Local reference clones of upstream Ent (comparison / inspection only,
# not a build dependency). Clone manually when needed.
.references/

# Ent-generated code in benchmark fixtures. We author the schemas
# (tracked under ent/schema/) but do not vendor Ent's generator output —
# benchmarks/run.sh regenerates it locally on first run.
benchmarks/fixtures/ent/ent/*
!benchmarks/fixtures/ent/ent/schema
!benchmarks/fixtures/ent/ent/schema/**
.worktrees/

# Velox loader temp directory (cleaned up automatically, but just in case)
.velox/

# Transient bench run output. testdata/bench-baseline.txt IS tracked
# (frozen reference); testdata/bench-current.txt is the per-run output.
testdata/bench-current.txt
